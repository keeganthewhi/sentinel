#!/usr/bin/env bash
# sentinel — one-command bootstrap that prepares the host and runs Sentinel.
#
# North Star UX:
#   git clone https://github.com/keeganthewhi/sentinel.git
#   cd sentinel
#   ./sentinel start --repo /path/to/your/code
#
# Bash 3.2+ compatible (no `[[ var =~ ... ]]` requiring 4+, no associative arrays).
# Run from the repo root.
#
# Order of operations (each step is fail-fast):
#   1. Verify Node 22+, pnpm 9+, Docker
#   2. Run `pnpm install` if node_modules is missing (postinstall also runs
#      `prisma generate` so the @prisma/client types get materialised).
#   3. Build TypeScript if dist/cli.js is missing
#   4. Detect WSL and note path rewriting
#   5. Start the sentinel-redis container if not running
#   6. Build the scanner image if not present
#   7. Apply Prisma migrations (`prisma migrate deploy`) — tolerant
#   8. Conditionally clone shannon-noapi when --shannon is in argv
#   9. Export runtime env vars and exec node dist/cli.js "$@"

set -e
set -u

REDIS_CONTAINER="sentinel-redis"
REDIS_IMAGE="redis:7-alpine"
SCANNER_IMAGE="sentinel-scanner:latest"
DATA_DIR="$(pwd)/data"
DATABASE_URL="file:./data/sentinel.db"
SHANNON_REPO="https://github.com/keeganthewhi/shannon-noapi.git"
SHANNON_DIR="$(pwd)/tools/shannon-noapi"

err() {
  printf '[sentinel] ERROR: %s\n' "$1" >&2
  exit "${2:-1}"
}

info() {
  printf '[sentinel] %s\n' "$1"
}

# 1. Toolchain verification
command -v node >/dev/null 2>&1 || err "node is not on PATH (Node.js 22+ required)" 2
command -v pnpm >/dev/null 2>&1 || err "pnpm is not on PATH (pnpm 9+ required)" 2
command -v docker >/dev/null 2>&1 || err "docker is not on PATH" 2

NODE_MAJOR=$(node --version | sed -E 's/^v([0-9]+)\..*/\1/')
if [ -z "$NODE_MAJOR" ] || [ "$NODE_MAJOR" -lt 22 ]; then
  err "Node.js 22+ required (have $(node --version))" 2
fi

# Verify Docker daemon is reachable.
docker info >/dev/null 2>&1 || err "Docker daemon is not running. Start Docker Desktop or 'sudo systemctl start docker'." 2

# 2. Install node dependencies if missing (postinstall hook runs prisma generate)
if [ ! -d node_modules ]; then
  info "Installing node dependencies (first run) — runs prisma generate via postinstall"
  pnpm install
fi

# 3. Build TypeScript if dist/ is stale
if [ ! -f dist/cli.js ]; then
  info "Building TypeScript (dist/cli.js missing)"
  pnpm build
fi

# 4. WSL path rewriting (Windows host running Docker Desktop with WSL2 backend)
if grep -qi microsoft /proc/version 2>/dev/null; then
  info "WSL detected — Docker bind mounts will use Windows-style paths"
fi

# 5. Redis container
if ! docker ps --format '{{.Names}}' | grep -q "^${REDIS_CONTAINER}$"; then
  if docker ps -a --format '{{.Names}}' | grep -q "^${REDIS_CONTAINER}$"; then
    info "Starting existing ${REDIS_CONTAINER} container"
    docker start "$REDIS_CONTAINER" >/dev/null
  else
    info "Creating ${REDIS_CONTAINER} container"
    docker run -d --name "$REDIS_CONTAINER" -p 127.0.0.1:6379:6379 "$REDIS_IMAGE" >/dev/null
  fi
fi

# 5b. (Temporal is started after Shannon clone — see step 8b below)

# 6. Scanner image
if ! docker image inspect "$SCANNER_IMAGE" >/dev/null 2>&1; then
  if [ -f docker/scanner.Dockerfile ]; then
    info "Building scanner image (this may take a few minutes on first run)"
    docker build -t "$SCANNER_IMAGE" -f docker/scanner.Dockerfile . >/dev/null
  else
    info "WARNING: scanner image '${SCANNER_IMAGE}' not found and docker/scanner.Dockerfile is missing"
  fi
fi

# 7. Prisma migrate (idempotent, tolerant)
mkdir -p "$DATA_DIR"
if [ -d node_modules ]; then
  DATABASE_URL="$DATABASE_URL" pnpm exec prisma migrate deploy >/dev/null 2>&1 || true
fi

# 8. Shannon clone (auto when --governed is present — governed mode implies
#    full Phase 3 exploitation, which requires the shannon-noapi checkout).
case " $* " in
  *" --governed "*)
    if [ ! -d "$SHANNON_DIR" ]; then
      info "Cloning shannon-noapi to $SHANNON_DIR (required by --governed)"
      mkdir -p "$(dirname "$SHANNON_DIR")"
      git clone "$SHANNON_REPO" "$SHANNON_DIR" >/dev/null
    fi
    # Build shannon CLI dist if missing so scanner.shannon can invoke it.
    if [ ! -f "$SHANNON_DIR/apps/cli/dist/index.mjs" ]; then
      info "Building shannon CLI (first --governed run)"
      (cd "$SHANNON_DIR" && pnpm install >/dev/null 2>&1 && pnpm build >/dev/null 2>&1) \
        || info "WARNING: shannon CLI build failed — Phase 3 will fail to invoke shannon"
    fi
    # Build shannon worker Docker image if missing. This is the container
    # that actually runs the 5-phase AI pentest pipeline. First build
    # takes ~5-10 minutes (installs Chromium, agent CLIs, Playwright).
    if ! docker image inspect shannon-worker:latest >/dev/null 2>&1; then
      info "Building shannon-worker Docker image (first --governed run, ~5-10 min)"
      (cd "$SHANNON_DIR" && node shannon build 2>&1) \
        || info "WARNING: shannon-worker image build failed — Phase 3 will fail"
    fi
    # Run shannon setup if .env is missing — creates .env with the
    # auto-detected agent CLI (claude/codex/gemini) so the worker
    # container knows which CLI to use for its AI queries.
    if [ ! -f "$SHANNON_DIR/.env" ]; then
      info "Running shannon setup (auto-detecting agent CLI)"
      (cd "$SHANNON_DIR" && node shannon setup >/dev/null 2>&1) \
        || info "WARNING: shannon setup failed — Phase 3 may fail to authenticate"
    fi
    # 8b. Start Temporal (Shannon's workflow orchestrator). Must happen
    #     AFTER Shannon is cloned because the docker-compose.yml lives
    #     inside the shannon checkout. Shannon's own ensureInfra() can't
    #     start it reliably from sentinel's whitelisted subprocess env.
    if ! docker ps --format '{{.Names}}' | grep -q '^shannon-temporal$'; then
      if docker ps -a --format '{{.Names}}' | grep -q '^shannon-temporal$'; then
        info "Starting existing shannon-temporal container"
        docker start shannon-temporal >/dev/null
      else
        info "Starting Temporal for Shannon"
        (cd "$SHANNON_DIR" && docker compose up -d temporal >/dev/null 2>&1) || true
      fi
      # Wait for Temporal to be healthy (up to 60s)
      info "Waiting for Temporal to be ready..."
      for i in $(seq 1 30); do
        if docker exec shannon-temporal temporal operator cluster health --address localhost:7233 2>/dev/null | grep -q SERVING; then
          info "Temporal is ready"
          break
        fi
        sleep 2
      done
    fi
    ;;
esac

# 9. Export runtime env
export REDIS_URL="redis://127.0.0.1:6379"
export DATABASE_URL
export SCANNER_IMAGE
export DATA_DIR
export SHANNON_DIR
# Respect the user's SENTINEL_GOVERNOR_CLI if set, otherwise let the adapter
# auto-detect claude / cursor-agent / codex / gemini on PATH.
if [ -n "${SENTINEL_GOVERNOR_CLI:-}" ]; then
  export SENTINEL_GOVERNOR_CLI
fi

exec node dist/cli.js "$@"
