{
  "name": "sentinel",
  "version": "0.1.3",
  "description": "Unified Application Security Testing Platform — self-hosted security scanner orchestrator with optional AI governor",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/main.js",
  "bin": {
    "sentinel": "dist/cli.js"
  },
  "scripts": {
    "postinstall": "prisma generate || echo 'prisma generate failed — run manually if persistence is needed'",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.73.4",
    "commander": "^12.1.0",
    "fast-xml-parser": "^5.5.11",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.0",
    "ora": "^9.3.0",
    "pdfmake": "^0.3.7",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/pdfmake": "^0.3.2",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prisma": "^7.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
